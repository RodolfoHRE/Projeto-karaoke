# Molde de variáveis de ambiente. Copie para `.env` e preencha.
#   cp .env.example .env
# O arquivo .env é gitignored (não vai pro repositório).

# Chave da YouTube Data API v3 (usada na busca por texto).
# Como obter: https://console.cloud.google.com/apis/credentials
# Sem chave, a busca por texto fica desativada — colar link/ID do YouTube ainda toca.
YOUTUBE_API_KEY=
